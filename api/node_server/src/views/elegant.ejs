<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Invoice — <%= locals.project_name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
  <style>
    <%- `
    :root {
      --accent: ${locals.theme_color || '#1e3a5f'};
      --accent-light: ${locals.theme_color_light || '#f0f4f9'};
      --gold: #c9a84c;
    }
    ` %>

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    @page { size: A4; margin: 0; }

    body {
      font-family: 'Lato', Georgia, serif;
      background: #f5f3ef;
      color: #1a1a1a;
      font-size: 13.5px;
      line-height: 1.6;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    @media print {
      body { background: #fff; }
      * { animation: none !important; transition: none !important; }
      .page { box-shadow: none; margin: 0; }
    }

    .serif { font-family: 'Cormorant Garamond', Georgia, serif; }

    .page {
      background: #ffffff;
      max-width: 800px;
      margin: 32px auto;
      padding: 0;
      box-shadow: 0 4px 28px rgba(0,0,0,0.10);
    }

    /* ── MASTHEAD ───────────────────────────────────────── */
    .masthead {
      padding: 44px 56px 32px;
      text-align: center;
      border-bottom: 1px solid #e8e4de;
      position: relative;
    }

    .masthead-logo {
      max-height: 60px;
      width: auto;
      object-fit: contain;
      display: block;
      margin: 0 auto 14px;
    }

    .masthead-monogram {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: var(--accent);
      color: #fff;
      font-family: 'Cormorant Garamond', serif;
      font-size: 28px;
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
    }

    .masthead-company {
      font-family: 'Cormorant Garamond', serif;
      font-size: 28px;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 1px;
    }

    .masthead-contact {
      font-size: 11.5px;
      color: #888;
      font-weight: 300;
      letter-spacing: 0.5px;
      margin-top: 6px;
    }

    .masthead-contact span + span::before { content: ' · '; }

    /* Double gold decorative rule */
    .gold-rule-wrap {
      margin: 20px 0 0;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .gold-rule { height: 2px; background: var(--gold); }
    .gold-rule-thin { height: 1px; background: var(--gold); opacity: 0.5; }

    /* ── INVOICE META ───────────────────────────────────── */
    .invoice-meta {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding: 28px 56px 0;
    }

    .invoice-heading {
      font-family: 'Cormorant Garamond', serif;
      font-size: 36px;
      font-weight: 600;
      font-style: italic;
      color: var(--accent);
      letter-spacing: 1px;
      line-height: 1;
    }

    .invoice-detail-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #aaa;
      margin-bottom: 2px;
    }

    .invoice-detail-value {
      font-size: 13.5px;
      font-weight: 400;
      color: #333;
    }

    /* ── BILL TO ────────────────────────────────────────── */
    .billing-section {
      padding: 24px 56px 20px;
      border-bottom: 1px solid #e8e4de;
    }

    .billing-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 8px;
    }

    .client-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 20px;
      font-weight: 600;
      color: var(--accent);
    }

    .client-detail {
      font-size: 12.5px;
      color: #5a5a5a;
      font-weight: 300;
      margin-top: 4px;
      line-height: 1.65;
      white-space: pre-line;
    }

    .client-email { font-size: 12.5px; color: #5a5a5a; font-weight: 300; margin-top: 2px; }

    /* ── TABLE ──────────────────────────────────────────── */
    .table-wrapper { padding: 24px 56px 0; }

    table { width: 100%; border-collapse: collapse; }

    thead th {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--accent);
      padding: 10px 12px 10px 0;
      text-align: left;
      border-bottom: 2px solid var(--accent);
    }

    thead th:last-child { text-align: right; padding-right: 0; }
    thead th.num        { text-align: right; }

    tbody td {
      padding: 12px 12px 12px 0;
      font-size: 13px;
      color: #3a3a3a;
      font-weight: 300;
      border-bottom: 1px solid #ece8e2;
      vertical-align: top;
    }

    tbody td:last-child { text-align: right; padding-right: 0; font-weight: 400; }
    tbody td.num        { text-align: right; font-weight: 400; }

    tbody tr:last-child td { border-bottom: none; }

    /* ── TOTALS (dot-leader style) ──────────────────────── */
    .totals-outer {
      display: flex;
      justify-content: flex-end;
      padding: 28px 56px 32px;
    }

    .totals-block { width: 300px; }

    .totals-line {
      display: flex;
      align-items: baseline;
      padding: 5px 0;
      border-bottom: 1px dotted #ccc;
    }

    .totals-line:last-of-type { border-bottom: none; }

    .totals-line-label {
      font-size: 12px;
      color: #666;
      font-weight: 300;
      flex-shrink: 0;
    }

    .totals-line-dots {
      flex: 1;
      border-bottom: 1px dotted #ccc;
      margin: 0 8px 3px;
      min-width: 20px;
    }

    .totals-line-value {
      font-size: 13px;
      color: #333;
      font-weight: 400;
      flex-shrink: 0;
    }

    .totals-line.discount .totals-line-value { color: #16a34a; }

    .totals-grand {
      border-top: 1px solid var(--accent);
      margin-top: 8px;
      padding-top: 12px;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }

    .totals-grand-label {
      font-family: 'Cormorant Garamond', serif;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--accent);
    }

    .totals-grand-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 26px;
      font-weight: 700;
      color: var(--accent);
    }

    /* ── SIGNATURE ──────────────────────────────────────── */
    .signature-section {
      margin: 0 56px 28px;
      padding-top: 24px;
      border-top: 1px solid #e8e4de;
      display: flex;
      align-items: flex-end;
      gap: 32px;
    }

    .sig-block { min-width: 200px; }
    .sig-img   { max-height: 52px; max-width: 180px; object-fit: contain; display: block; }
    .sig-line  { border-top: 1px solid #bbb; margin-top: 8px; padding-top: 5px; font-size: 11px; color: #999; letter-spacing: 1px; text-transform: uppercase; }

    /* ── TERMS ──────────────────────────────────────────── */
    .terms-section {
      margin: 0 56px 32px;
      padding: 16px 0;
      border-top: 1px solid #e8e4de;
    }

    .terms-label { font-size: 10px; font-weight: 700; letter-spacing: 1.8px; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }
    .terms-text  { font-size: 12px; color: #777; font-weight: 300; line-height: 1.8; white-space: pre-line; }

    /* ── FOOTER ─────────────────────────────────────────── */
    .footer-gold-rule { margin: 0 56px; }

    .footer {
      padding: 20px 56px;
      text-align: center;
    }

    .footer-thanks {
      font-family: 'Cormorant Garamond', serif;
      font-size: 16px;
      font-style: italic;
      color: #aaa;
      font-weight: 400;
    }
  </style>
</head>
<body>
<%
const fmt = (n) => {
  const sym = locals.currency || '$';
  return sym + Number(n || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
};
const companyInitial = (locals.company_name || 'C').charAt(0).toUpperCase();
%>
<div class="page">

  <!-- MASTHEAD -->
  <div class="masthead">
    <% if (locals.logo_url) { %>
      <img class="masthead-logo" src="<%= locals.logo_url %>" alt="Logo" />
    <% } else { %>
      <div class="masthead-monogram serif"><%= companyInitial %></div>
    <% } %>
    <div class="masthead-company"><%= locals.company_name || '' %></div>
    <div class="masthead-contact">
      <% if (locals.company_address) { %><span><%= locals.company_address %></span><% } %>
      <% if (locals.company_phone)   { %><span><%= locals.company_phone %></span><% } %>
      <% if (locals.company_email)   { %><span><%= locals.company_email %></span><% } %>
    </div>
    <div class="gold-rule-wrap">
      <div class="gold-rule"></div>
      <div class="gold-rule-thin"></div>
    </div>
  </div>

  <!-- INVOICE META -->
  <div class="invoice-meta" style="padding-bottom: 24px; border-bottom: 1px solid #e8e4de;">
    <div class="invoice-heading">Invoice</div>
    <div style="text-align:right">
      <div class="invoice-detail-label">Date</div>
      <div class="invoice-detail-value"><%= locals.date || new Date().toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></div>
      <div class="invoice-detail-label" style="margin-top:10px">Project</div>
      <div class="invoice-detail-value"><%= locals.project_name || '' %></div>
    </div>
  </div>

  <!-- BILL TO -->
  <div class="billing-section">
    <div class="billing-label">Prepared For</div>
    <div class="client-name"><%= locals.client_name || '' %></div>
    <div class="client-detail"><%= locals.client_address || '' %></div>
    <% if (locals.client_email) { %><div class="client-email"><%= locals.client_email %></div><% } %>
  </div>

  <!-- LINE ITEMS -->
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th style="width:50%">Description</th>
          <th class="num">Qty</th>
          <th class="num">Unit Price</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        <% (locals.line_items || []).forEach(function(item) { %>
        <tr>
          <td><%= item.description %></td>
          <td class="num"><%= Number(item.quantity || 0).toLocaleString('en-US', {maximumFractionDigits:2}) %></td>
          <td class="num"><%= fmt(item.unit_price) %></td>
          <td><%= fmt(item.total || (item.quantity * item.unit_price)) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- TOTALS -->
  <div class="totals-outer">
    <div class="totals-block">
      <div class="totals-line">
        <span class="totals-line-label">Subtotal</span>
        <span class="totals-line-dots"></span>
        <span class="totals-line-value"><%= fmt(locals.subtotal) %></span>
      </div>
      <% if (locals.discount && Number(locals.discount) > 0) { %>
      <div class="totals-line discount">
        <span class="totals-line-label">Discount</span>
        <span class="totals-line-dots"></span>
        <span class="totals-line-value">-<%= fmt(locals.discount) %></span>
      </div>
      <% } %>
      <div class="totals-line">
        <span class="totals-line-label">Tax</span>
        <span class="totals-line-dots"></span>
        <span class="totals-line-value"><%= fmt(locals.taxes) %></span>
      </div>
      <div class="totals-grand">
        <span class="totals-grand-label">Total Due</span>
        <span class="totals-grand-value"><%= fmt(locals.total) %></span>
      </div>
    </div>
  </div>

  <!-- SIGNATURE -->
  <% if (locals.show_signature && locals.signature) { %>
  <div class="signature-section">
    <div class="sig-block">
      <img class="sig-img" src="<%= locals.signature %>" alt="Signature" />
      <div class="sig-line">Authorized Signature</div>
    </div>
  </div>
  <% } %>

  <!-- TERMS -->
  <% if (locals.terms) { %>
  <div class="terms-section">
    <div class="terms-label">Terms &amp; Conditions</div>
    <div class="terms-text"><%= locals.terms %></div>
  </div>
  <% } %>

  <!-- FOOTER -->
  <div class="footer-gold-rule">
    <div class="gold-rule-wrap">
      <div class="gold-rule-thin"></div>
      <div class="gold-rule"></div>
    </div>
  </div>
  <div class="footer">
    <div class="footer-thanks">Thank you for your continued trust and business.</div>
  </div>

</div>
</body>
</html>
