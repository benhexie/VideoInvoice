<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Invoice — <%= locals.project_name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet" />
  <style>
    <%- `
    :root {
      --accent: ${locals.theme_color || '#d4a853'};
      --accent-light: ${locals.theme_color_light || '#fef9ec'};
      --dark: #1a1a2e;
      --dark-2: #16213e;
    }
    ` %>

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    @page { size: A4; margin: 0; }

    body {
      font-family: 'Source Sans 3', 'Helvetica Neue', sans-serif;
      background: #0d0d1a;
      color: #1a1a1a;
      font-size: 13.5px;
      line-height: 1.55;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    @media print {
      body { background: #fff; }
      * { animation: none !important; transition: none !important; }
      .page { box-shadow: none; margin: 0; }
    }

    .serif { font-family: 'Playfair Display', Georgia, serif; }

    .page {
      background: #fafafa;
      max-width: 800px;
      margin: 32px auto;
      overflow: hidden;
      box-shadow: 0 8px 48px rgba(0,0,0,0.4);
    }

    /* ── DARK HEADER ────────────────────────────────────── */
    .dark-header {
      background: var(--dark);
      padding: 40px 52px 36px;
      position: relative;
      overflow: hidden;
    }

    /* Subtle texture overlay */
    .dark-header::before {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        45deg,
        transparent,
        transparent 2px,
        rgba(255,255,255,0.015) 2px,
        rgba(255,255,255,0.015) 4px
      );
    }

    .header-content {
      position: relative;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }

    .header-left {}

    .company-logo {
      max-height: 44px;
      width: auto;
      object-fit: contain;
      filter: brightness(0) invert(1);
      margin-bottom: 12px;
      display: block;
    }

    .company-name {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 26px;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 0.5px;
    }

    .company-meta {
      font-size: 12px;
      color: rgba(255,255,255,0.5);
      margin-top: 6px;
      font-weight: 300;
      line-height: 1.7;
    }

    .header-right { text-align: right; }

    .invoice-word {
      font-family: 'Playfair Display', serif;
      font-size: 36px;
      font-weight: 700;
      font-style: italic;
      color: #ffffff;
      letter-spacing: 2px;
      line-height: 1;
    }

    .invoice-date-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-top: 10px;
    }

    .invoice-date-value {
      font-size: 13px;
      color: rgba(255,255,255,0.8);
      margin-top: 2px;
    }

    /* Gold separator */
    .gold-separator {
      height: 1px;
      background: linear-gradient(to right, transparent, var(--accent), transparent);
      margin: 0;
    }

    /* ── BODY SECTION ───────────────────────────────────── */
    .body-section { background: #ffffff; }

    /* ── BILLING + PROJECT ──────────────────────────────── */
    .meta-section {
      padding: 32px 52px;
      display: flex;
      gap: 0;
      border-bottom: 1px solid #eeeeee;
    }

    .meta-col { flex: 1; }
    .meta-col:last-child { border-left: 1px solid #eee; padding-left: 40px; }
    .meta-col:first-child { padding-right: 40px; }

    .meta-label {
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
    }

    .meta-name {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      font-weight: 600;
      color: #111;
      margin-bottom: 4px;
    }

    .meta-detail {
      font-size: 12.5px;
      color: #777;
      font-weight: 300;
      line-height: 1.65;
      white-space: pre-line;
    }

    /* ── TABLE ──────────────────────────────────────────── */
    .table-wrapper { padding: 0 52px 8px; background: #fff; }

    .table-heading {
      padding: 24px 52px 10px;
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: #999;
    }

    table { width: 100%; border-collapse: collapse; }

    thead th {
      background: var(--dark);
      color: var(--accent);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 12px 14px;
      text-align: left;
    }

    thead th:last-child { text-align: right; }
    thead th.num        { text-align: right; }

    tbody tr { border-bottom: 1px solid #f0f0f0; }

    tbody td {
      padding: 13px 14px;
      font-size: 13px;
      color: #3a3a3a;
      font-weight: 300;
      vertical-align: top;
    }

    tbody td:last-child { text-align: right; font-weight: 400; }
    tbody td.num        { text-align: right; }

    tbody tr:nth-child(even) { background: #fafafa; }
    tbody tr:last-child { border-bottom: none; }

    /* ── DARK TOTALS BAND ───────────────────────────────── */
    .dark-totals {
      background: var(--dark);
      padding: 32px 52px;
      position: relative;
      overflow: hidden;
    }

    /* Watermark */
    .dark-totals::before {
      content: 'INVOICE';
      position: absolute;
      right: -10px;
      top: 50%;
      transform: translateY(-50%);
      font-family: 'Playfair Display', serif;
      font-size: 110px;
      font-weight: 700;
      font-style: italic;
      color: rgba(255,255,255,0.04);
      letter-spacing: 4px;
      user-select: none;
      pointer-events: none;
      white-space: nowrap;
    }

    .totals-content {
      position: relative;
      display: flex;
      justify-content: flex-end;
    }

    .totals-block { width: 300px; }

    .totals-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 7px 0;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .totals-row:last-of-type { border-bottom: none; }

    .totals-row-label { font-size: 13px; font-weight: 300; color: rgba(255,255,255,0.6); }
    .totals-row-value { font-size: 13px; font-weight: 400; color: rgba(255,255,255,0.85); }
    .totals-row.discount .totals-row-value { color: #6ee7b7; }

    .totals-grand {
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid var(--accent);
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }

    .totals-grand-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.7);
    }

    .totals-grand-value {
      font-family: 'Playfair Display', serif;
      font-size: 30px;
      font-weight: 700;
      color: var(--accent);
    }

    /* ── SIGNATURE SECTION ──────────────────────────────── */
    .signature-section {
      background: #fff;
      padding: 28px 52px;
      border-bottom: 1px solid #eee;
    }

    .sig-label { font-size: 10px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: #aaa; margin-bottom: 10px; }
    .sig-img   { max-height: 52px; max-width: 180px; object-fit: contain; display: block; }
    .sig-line  { border-top: 1px solid #ccc; margin-top: 8px; padding-top: 5px; font-size: 11px; color: #888; letter-spacing: 1px; }

    /* ── TERMS ──────────────────────────────────────────── */
    .terms-section {
      background: #fff;
      padding: 20px 52px;
      border-bottom: 1px solid #eee;
    }

    .terms-label { font-size: 10px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); margin-bottom: 8px; }
    .terms-text  { font-size: 12px; color: #777; font-weight: 300; line-height: 1.8; white-space: pre-line; }

    /* ── FOOTER ─────────────────────────────────────────── */
    .footer {
      background: #fff;
      padding: 20px 52px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer-thanks {
      font-family: 'Playfair Display', serif;
      font-size: 15px;
      font-style: italic;
      color: #bbb;
    }

    .footer-contact {
      font-size: 11px;
      color: #aaa;
      font-weight: 300;
      text-align: right;
      line-height: 1.7;
    }
  </style>
</head>
<body>
<%
const fmt = (n) => {
  const sym = locals.currency || '$';
  return sym + Number(n || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
};
const companyInitial = (locals.company_name || 'C').charAt(0).toUpperCase();
%>
<div class="page">

  <!-- DARK HEADER -->
  <div class="dark-header">
    <div class="header-content">
      <div class="header-left">
        <% if (locals.logo_url) { %>
          <img class="company-logo" src="<%= locals.logo_url %>" alt="Logo" />
        <% } %>
        <div class="company-name"><%= locals.company_name || '' %></div>
        <div class="company-meta">
          <% if (locals.company_address) { %><div><%= locals.company_address %></div><% } %>
          <% if (locals.company_phone)   { %><div><%= locals.company_phone %></div><% } %>
          <% if (locals.company_email)   { %><div><%= locals.company_email %></div><% } %>
        </div>
      </div>
      <div class="header-right">
        <div class="invoice-word">Invoice</div>
        <div class="invoice-date-label">Date</div>
        <div class="invoice-date-value"><%= locals.date || new Date().toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></div>
      </div>
    </div>
  </div>

  <!-- GOLD SEPARATOR -->
  <div class="gold-separator"></div>

  <!-- BODY -->
  <div class="body-section">

    <!-- BILLING + PROJECT -->
    <div class="meta-section">
      <div class="meta-col">
        <div class="meta-label">Billed To</div>
        <div class="meta-name"><%= locals.client_name || '' %></div>
        <div class="meta-detail"><%= locals.client_address || '' %></div>
        <% if (locals.client_email) { %><div class="meta-detail"><%= locals.client_email %></div><% } %>
      </div>
      <div class="meta-col">
        <div class="meta-label">Project</div>
        <div class="meta-name"><%= locals.project_name || '' %></div>
      </div>
    </div>

    <!-- TABLE HEADING -->
    <div class="table-heading">Services &amp; Materials</div>

    <!-- LINE ITEMS TABLE -->
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th style="width:50%">Description</th>
            <th class="num">Qty</th>
            <th class="num">Unit Price</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          <% (locals.line_items || []).forEach(function(item) { %>
          <tr>
            <td><%= item.description %></td>
            <td class="num"><%= Number(item.quantity || 0).toLocaleString('en-US', {maximumFractionDigits:2}) %></td>
            <td class="num"><%= fmt(item.unit_price) %></td>
            <td><%= fmt(item.total || (item.quantity * item.unit_price)) %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </div>

  <!-- DARK TOTALS BAND -->
  <div class="dark-totals">
    <div class="totals-content">
      <div class="totals-block">
        <div class="totals-row">
          <span class="totals-row-label">Subtotal</span>
          <span class="totals-row-value"><%= fmt(locals.subtotal) %></span>
        </div>
        <% if (locals.discount && Number(locals.discount) > 0) { %>
        <div class="totals-row discount">
          <span class="totals-row-label">Discount</span>
          <span class="totals-row-value">-<%= fmt(locals.discount) %></span>
        </div>
        <% } %>
        <div class="totals-row">
          <span class="totals-row-label">Tax</span>
          <span class="totals-row-value"><%= fmt(locals.taxes) %></span>
        </div>
        <div class="totals-grand">
          <span class="totals-grand-label">Total Due</span>
          <span class="totals-grand-value"><%= fmt(locals.total) %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- SIGNATURE -->
  <% if (locals.show_signature && locals.signature) { %>
  <div class="signature-section">
    <div class="sig-label">Authorized Signature</div>
    <img class="sig-img" src="<%= locals.signature %>" alt="Signature" />
    <div class="sig-line"><%= locals.company_name || '' %></div>
  </div>
  <% } %>

  <!-- TERMS -->
  <% if (locals.terms) { %>
  <div class="terms-section">
    <div class="terms-label">Terms &amp; Conditions</div>
    <div class="terms-text"><%= locals.terms %></div>
  </div>
  <% } %>

  <!-- FOOTER -->
  <div class="footer">
    <div class="footer-thanks">Thank you for your business.</div>
    <div class="footer-contact">
      <% if (locals.company_email) { %><div><%= locals.company_email %></div><% } %>
      <% if (locals.company_phone) { %><div><%= locals.company_phone %></div><% } %>
    </div>
  </div>

</div>
</body>
</html>
