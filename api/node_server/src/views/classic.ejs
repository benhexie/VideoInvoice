<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Invoice — <%= locals.project_name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet" />
  <style>
    <%- `
    :root {
      --accent: ${locals.theme_color || '#1d4ed8'};
      --accent-light: ${locals.theme_color_light || '#eff6ff'};
    }
    ` %>

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    @page { size: A4; margin: 0; }

    body {
      font-family: 'Open Sans', Arial, sans-serif;
      background: #f0f0f0;
      color: #111111;
      font-size: 13.5px;
      line-height: 1.55;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    @media print {
      body { background: #fff; }
      * { animation: none !important; transition: none !important; }
      .page { box-shadow: none; margin: 0; }
    }

    .page {
      background: #ffffff;
      max-width: 800px;
      margin: 32px auto;
      box-shadow: 0 2px 20px rgba(0,0,0,0.12);
    }

    /* ── TOP RULE ───────────────────────────────────────── */
    .top-rule { height: 4px; background: var(--accent); }

    /* ── LETTERHEAD ─────────────────────────────────────── */
    .letterhead {
      padding: 32px 48px 24px;
      display: flex;
      align-items: flex-start;
      gap: 20px;
      border-bottom: 1px solid #dddddd;
    }

    .company-logo-wrap {
      flex-shrink: 0;
    }

    .company-logo-wrap img {
      height: 64px;
      width: auto;
      object-fit: contain;
    }

    .company-monogram {
      width: 64px;
      height: 64px;
      background: var(--accent);
      color: #fff;
      font-family: 'Merriweather', serif;
      font-size: 26px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 4px;
    }

    .company-info {
      border-left: 4px solid var(--accent);
      padding-left: 16px;
    }

    .company-name {
      font-family: 'Merriweather', serif;
      font-size: 22px;
      font-weight: 700;
      color: #111;
      letter-spacing: -0.3px;
    }

    .company-tagline {
      font-size: 12px;
      color: #777;
      margin-top: 3px;
    }

    .company-details {
      font-size: 12px;
      color: #555;
      margin-top: 6px;
      line-height: 1.6;
    }

    /* ── INVOICE META BAR ───────────────────────────────── */
    .meta-bar {
      display: flex;
      background: var(--accent-light);
      border-bottom: 2px solid var(--accent);
      padding: 14px 48px;
      gap: 40px;
    }

    .meta-item-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 2px;
    }

    .meta-item-value {
      font-family: 'Merriweather', serif;
      font-size: 14px;
      font-weight: 700;
      color: #111;
    }

    .meta-invoice-label {
      margin-left: auto;
    }

    .meta-invoice-title {
      font-family: 'Merriweather', serif;
      font-size: 26px;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 1px;
      line-height: 1;
    }

    /* ── BILL TO ────────────────────────────────────────── */
    .billing-section {
      padding: 24px 48px;
      border-bottom: 1px solid #dddddd;
    }

    .billing-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #999;
      margin-bottom: 8px;
    }

    .client-name {
      font-family: 'Merriweather', serif;
      font-size: 16px;
      font-weight: 700;
      color: #111;
      margin-bottom: 4px;
    }

    .client-address {
      font-size: 13px;
      color: #555;
      line-height: 1.6;
      white-space: pre-line;
    }

    .client-email {
      font-size: 13px;
      color: #555;
      margin-top: 2px;
    }

    /* ── TABLE ──────────────────────────────────────────── */
    .table-wrapper { padding: 24px 48px 0; }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead th {
      background: var(--accent);
      color: #ffffff;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.6px;
      text-transform: uppercase;
      padding: 11px 14px;
      text-align: left;
      border: 1px solid var(--accent);
    }

    thead th.num { text-align: right; }
    thead th:last-child { text-align: right; }

    tbody td {
      padding: 10px 14px;
      font-size: 13px;
      color: #333;
      border: 1px solid #dddddd;
      vertical-align: top;
    }

    tbody td.num { text-align: right; }
    tbody td:last-child { text-align: right; font-weight: 600; }

    tbody tr:nth-child(even) { background: #f7f7f7; }

    /* ── TOTALS ─────────────────────────────────────────── */
    .totals-outer {
      display: flex;
      justify-content: flex-end;
      padding: 24px 48px 28px;
    }

    .totals-table {
      width: 280px;
      border-collapse: collapse;
    }

    .totals-table td {
      padding: 8px 12px;
      font-size: 13px;
      color: #444;
      border: none;
    }

    .totals-table td:last-child {
      text-align: right;
      font-weight: 600;
    }

    .totals-table tr.subtotal-row td { border-top: 1px solid #ddd; }

    .totals-table tr.total-row td {
      font-family: 'Merriweather', serif;
      font-size: 15px;
      font-weight: 700;
      color: #111;
      border-top: 3px double #333;
      border-bottom: 3px double #333;
      padding-top: 10px;
      padding-bottom: 10px;
    }

    .totals-table tr.discount-row td { color: #16a34a; }

    /* ── SIGNATURE ──────────────────────────────────────── */
    .signature-section {
      margin: 0 48px 28px;
      display: flex;
      gap: 24px;
      align-items: flex-end;
    }

    .sig-block { min-width: 200px; }
    .sig-label  { font-size: 11px; color: #aaa; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }
    .sig-img    { max-height: 56px; max-width: 180px; object-fit: contain; display: block; }
    .sig-line   { border-top: 1px solid #bbb; padding-top: 4px; font-size: 11px; color: #666; }

    /* ── TERMS ──────────────────────────────────────────── */
    .terms-section {
      margin: 0 48px 28px;
      padding: 14px 18px;
      background: #fafafa;
      border: 1px solid #e0e0e0;
    }

    .terms-label { font-size: 10px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: #888; margin-bottom: 6px; }
    .terms-text  { font-size: 12px; color: #666; line-height: 1.7; white-space: pre-line; }

    /* ── FOOTER ─────────────────────────────────────────── */
    .footer {
      background: #f5f5f5;
      border-top: 1px solid #ddd;
      padding: 14px 48px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer-contact { font-size: 11px; color: #888; }
    .footer-contact span + span::before { content: ' · '; }

    /* ── BOTTOM RULE ────────────────────────────────────── */
    .bottom-rule { height: 4px; background: var(--accent); }
  </style>
</head>
<body>
<%
const fmt = (n) => {
  const sym = locals.currency || '$';
  return sym + Number(n || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
};
const companyInitial = (locals.company_name || 'C').charAt(0).toUpperCase();
%>
<div class="page">

  <!-- TOP RULE -->
  <div class="top-rule"></div>

  <!-- LETTERHEAD -->
  <div class="letterhead">
    <div class="company-logo-wrap">
      <% if (locals.logo_url) { %>
        <img src="<%= locals.logo_url %>" alt="Logo" />
      <% } else { %>
        <div class="company-monogram"><%= companyInitial %></div>
      <% } %>
    </div>
    <div class="company-info">
      <div class="company-name"><%= locals.company_name || '' %></div>
      <div class="company-details">
        <%= locals.company_address || '' %><br>
        <% if (locals.company_phone) { %><%= locals.company_phone %><% } %>
        <% if (locals.company_phone && locals.company_email) { %> &nbsp;|&nbsp; <% } %>
        <% if (locals.company_email) { %><%= locals.company_email %><% } %>
        <% if ((locals.company_phone || locals.company_email) && locals.company_website) { %> &nbsp;|&nbsp; <% } %><% if (locals.company_website) { %><%= locals.company_website %><% } %>
      </div>
    </div>
  </div>

  <!-- META BAR -->
  <div class="meta-bar">
    <div>
      <div class="meta-item-label">Date</div>
      <div class="meta-item-value"><%= locals.date || new Date().toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></div>
    </div>
    <div>
      <div class="meta-item-label">Project</div>
      <div class="meta-item-value"><%= locals.project_name || '' %></div>
    </div>
    <div class="meta-invoice-label" style="text-align:right">
      <div class="meta-invoice-title">INVOICE</div>
    </div>
  </div>

  <!-- BILL TO -->
  <div class="billing-section">
    <div class="billing-label">Bill To</div>
    <div class="client-name"><%= locals.client_name || '' %></div>
    <div class="client-address"><%= locals.client_address || '' %></div>
    <% if (locals.client_email) { %><div class="client-email"><%= locals.client_email %></div><% } %>
  </div>

  <!-- LINE ITEMS TABLE -->
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th style="width:50%">Description</th>
          <th class="num">Qty</th>
          <th class="num">Unit Price</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        <% (locals.line_items || []).forEach(function(item) { %>
        <tr>
          <td><%= item.description %></td>
          <td class="num"><%= Number(item.quantity || 0).toLocaleString('en-US', {maximumFractionDigits:2}) %></td>
          <td class="num"><%= fmt(item.unit_price) %></td>
          <td><%= fmt(item.total || (item.quantity * item.unit_price)) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- TOTALS -->
  <div class="totals-outer">
    <table class="totals-table">
      <tbody>
        <tr class="subtotal-row">
          <td>Subtotal</td>
          <td><%= fmt(locals.subtotal) %></td>
        </tr>
        <% if (locals.discount && Number(locals.discount) > 0) { %>
        <tr class="discount-row">
          <td>Discount</td>
          <td>-<%= fmt(locals.discount) %></td>
        </tr>
        <% } %>
        <tr>
          <td>Tax</td>
          <td><%= fmt(locals.taxes) %></td>
        </tr>
        <tr class="total-row">
          <td>Total Due</td>
          <td><%= fmt(locals.total) %></td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- SIGNATURE -->
  <% if (locals.show_signature && locals.signature) { %>
  <div class="signature-section">
    <div class="sig-block">
      <div class="sig-label">Authorized Signature</div>
      <img class="sig-img" src="<%= locals.signature %>" alt="Signature" />
      <div class="sig-line"><%= locals.company_name || '' %></div>
    </div>
  </div>
  <% } %>

  <!-- TERMS -->
  <% if (locals.terms) { %>
  <div class="terms-section">
    <div class="terms-label">Terms &amp; Conditions</div>
    <div class="terms-text"><%= locals.terms %></div>
  </div>
  <% } %>

  <!-- FOOTER -->
  <div class="footer">
    <div class="footer-contact">
      <% if (locals.company_name) { %><span><%= locals.company_name %></span><% } %>
      <% if (locals.company_email) { %><span><%= locals.company_email %></span><% } %>
      <% if (locals.company_phone) { %><span><%= locals.company_phone %></span><% } %>
      <% if (locals.company_website) { %><span><%= locals.company_website %></span><% } %>
    </div>
  </div>

  <!-- BOTTOM RULE -->
  <div class="bottom-rule"></div>

</div>
</body>
</html>
