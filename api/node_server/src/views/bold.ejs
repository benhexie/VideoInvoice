<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Invoice — <%= locals.project_name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Barlow+Condensed:wght@600;700;800&display=swap" rel="stylesheet" />
  <style>
    <%- `
    :root {
      --accent: ${locals.theme_color || '#dc2626'};
      --accent-light: ${locals.theme_color_light || '#fef2f2'};
    }
    ` %>

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    @page { size: A4; margin: 0; }

    body {
      font-family: 'Barlow', -apple-system, sans-serif;
      background: #e5e7eb;
      color: #111827;
      font-size: 13.5px;
      line-height: 1.5;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    @media print {
      body { background: #fff; }
      * { animation: none !important; transition: none !important; }
      .page { box-shadow: none; margin: 0; }
    }

    .page {
      background: #ffffff;
      max-width: 800px;
      margin: 32px auto;
      box-shadow: 0 4px 28px rgba(0,0,0,0.14);
    }

    /* ── HEADER BANNER ──────────────────────────────────── */
    .header-banner {
      background: var(--accent);
      padding: 32px 48px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .header-company-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 34px;
      font-weight: 800;
      color: #ffffff;
      letter-spacing: 0.5px;
      line-height: 1;
    }

    .header-company-sub {
      font-size: 12px;
      color: rgba(255,255,255,0.75);
      margin-top: 5px;
      font-weight: 400;
    }

    .header-logo {
      max-height: 52px;
      width: auto;
      object-fit: contain;
    }

    /* ── INVOICE IDENTITY BAR ───────────────────────────── */
    .identity-bar {
      background: #1f2937;
      padding: 14px 48px;
      display: flex;
      align-items: center;
      gap: 32px;
    }

    .invoice-big-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 42px;
      font-weight: 800;
      letter-spacing: 5px;
      color: rgba(255,255,255,0.12);
      line-height: 1;
      user-select: none;
    }

    .identity-meta { display: flex; gap: 32px; margin-left: auto; }

    .identity-item-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
      margin-bottom: 2px;
    }

    .identity-item-value {
      font-size: 13px;
      font-weight: 600;
      color: #ffffff;
    }

    /* ── SECTION LABEL ──────────────────────────────────── */
    .section-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 8px;
    }

    /* ── BILL TO / FROM ─────────────────────────────────── */
    .parties-row {
      display: flex;
      padding: 28px 48px;
      gap: 0;
      border-bottom: 1px solid #e5e7eb;
    }

    .party-block { flex: 1; padding-right: 32px; }
    .party-block:last-child { padding-right: 0; border-left: 1px solid #e5e7eb; padding-left: 32px; }

    .party-name {
      font-size: 16px;
      font-weight: 700;
      color: #111827;
      margin-bottom: 4px;
    }

    .party-detail {
      font-size: 12.5px;
      color: #6b7280;
      line-height: 1.65;
      white-space: pre-line;
    }

    /* ── PROJECT BAND ───────────────────────────────────── */
    .project-band {
      background: var(--accent-light);
      border-left: 5px solid var(--accent);
      padding: 14px 48px;
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .project-band-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--accent);
      flex-shrink: 0;
    }

    .project-band-name {
      font-size: 14px;
      font-weight: 700;
      color: #111827;
    }

    /* ── TABLE ──────────────────────────────────────────── */
    .table-section-label {
      padding: 20px 48px 8px;
    }

    .table-wrapper { padding: 0 48px; }

    table { width: 100%; border-collapse: collapse; }

    thead th {
      background: #1f2937;
      color: #ffffff;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      padding: 12px 14px;
      text-align: left;
    }

    thead th:last-child { text-align: right; }
    thead th.num        { text-align: right; }

    tbody tr { border-bottom: 1px solid #f3f4f6; }

    tbody td {
      padding: 13px 14px;
      font-size: 13px;
      color: #374151;
      vertical-align: top;
    }

    tbody td:first-child {
      border-left: 3px solid transparent;
    }

    tbody tr:hover td:first-child { border-left-color: var(--accent); }

    tbody td:last-child { text-align: right; font-weight: 600; }
    tbody td.num        { text-align: right; }

    tbody tr:nth-child(even) { background: #f9fafb; }

    /* ── TOTALS ─────────────────────────────────────────── */
    .totals-row-outer {
      padding: 24px 48px 28px;
      display: flex;
      justify-content: flex-end;
    }

    .totals-box {
      background: #1f2937;
      border-radius: 10px;
      overflow: hidden;
      width: 280px;
    }

    .totals-box-inner { padding: 4px 0; }

    .totals-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 20px;
      font-size: 13px;
      color: rgba(255,255,255,0.7);
    }

    .totals-item-value { font-weight: 600; color: rgba(255,255,255,0.9); }
    .totals-item.discount .totals-item-value { color: #6ee7b7; }

    .totals-grand-row {
      background: var(--accent);
      padding: 16px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .totals-grand-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #ffffff;
    }

    .totals-grand-value {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 26px;
      font-weight: 800;
      color: #ffffff;
      letter-spacing: 0.5px;
    }

    /* ── SIGNATURE ──────────────────────────────────────── */
    .signature-section {
      margin: 0 48px 24px;
      padding: 20px 24px;
      background: #f9fafb;
      border-radius: 8px;
    }

    .sig-label { font-size: 10px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #9ca3af; margin-bottom: 10px; }
    .sig-img   { max-height: 52px; max-width: 180px; object-fit: contain; display: block; }
    .sig-line  { border-top: 1px solid #d1d5db; margin-top: 8px; padding-top: 5px; font-size: 12px; color: #6b7280; }

    /* ── TERMS ──────────────────────────────────────────── */
    .terms-section {
      margin: 0 48px 24px;
      padding: 14px 18px;
      border-left: 3px solid var(--accent);
      background: var(--accent-light);
    }

    .terms-label { font-size: 9px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); margin-bottom: 6px; }
    .terms-text  { font-size: 12px; color: #4b5563; line-height: 1.7; white-space: pre-line; }

    /* ── FOOTER BANNER ──────────────────────────────────── */
    .footer-banner {
      background: var(--accent);
      padding: 16px 48px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer-thanks { font-family: 'Barlow Condensed', sans-serif; font-size: 16px; font-weight: 700; color: rgba(255,255,255,0.9); letter-spacing: 1px; }
    .footer-contact { font-size: 12px; color: rgba(255,255,255,0.75); text-align: right; }
  </style>
</head>
<body>
<%
const fmt = (n) => {
  const sym = locals.currency || '$';
  return sym + Number(n || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
};
%>
<div class="page">

  <!-- HEADER BANNER -->
  <div class="header-banner">
    <div>
      <div class="header-company-name"><%= locals.company_name || '' %></div>
      <div class="header-company-sub">
        <% if (locals.company_address) { %><%= locals.company_address %><% } %>
      </div>
    </div>
    <% if (locals.logo_url) { %>
      <img class="header-logo" src="<%= locals.logo_url %>" alt="Logo" />
    <% } %>
  </div>

  <!-- IDENTITY BAR -->
  <div class="identity-bar">
    <div class="invoice-big-label">INVOICE</div>
    <div class="identity-meta">
      <div>
        <div class="identity-item-label">Date</div>
        <div class="identity-item-value"><%= locals.date || new Date().toLocaleDateString('en-US', {year:'numeric',month:'short',day:'numeric'}) %></div>
      </div>
    </div>
  </div>

  <!-- PROJECT BAND -->
  <div class="project-band">
    <span class="project-band-label">Project</span>
    <span class="project-band-name"><%= locals.project_name || '' %></span>
  </div>

  <!-- PARTIES -->
  <div class="parties-row">
    <div class="party-block">
      <div class="section-label">Bill To</div>
      <div class="party-name"><%= locals.client_name || '' %></div>
      <div class="party-detail"><%= locals.client_address || '' %></div>
      <% if (locals.client_email) { %><div class="party-detail"><%= locals.client_email %></div><% } %>
    </div>
    <div class="party-block">
      <div class="section-label">From</div>
      <div class="party-name"><%= locals.company_name || '' %></div>
      <% if (locals.company_email) { %><div class="party-detail"><%= locals.company_email %></div><% } %>
      <% if (locals.company_phone) { %><div class="party-detail"><%= locals.company_phone %></div><% } %>
      <% if (locals.company_website) { %><div class="party-detail"><%= locals.company_website %></div><% } %>
    </div>
  </div>

  <!-- TABLE SECTION LABEL -->
  <div class="table-section-label">
    <div class="section-label">Line Items</div>
  </div>

  <!-- LINE ITEMS -->
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th style="width:50%">Description</th>
          <th class="num">Qty</th>
          <th class="num">Unit Price</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        <% (locals.line_items || []).forEach(function(item) { %>
        <tr>
          <td><%= item.description %></td>
          <td class="num"><%= Number(item.quantity || 0).toLocaleString('en-US', {maximumFractionDigits:2}) %></td>
          <td class="num"><%= fmt(item.unit_price) %></td>
          <td><%= fmt(item.total || (item.quantity * item.unit_price)) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- TOTALS -->
  <div class="totals-row-outer">
    <div class="totals-box">
      <div class="totals-box-inner">
        <div class="totals-item">
          <span>Subtotal</span>
          <span class="totals-item-value"><%= fmt(locals.subtotal) %></span>
        </div>
        <% if (locals.discount && Number(locals.discount) > 0) { %>
        <div class="totals-item discount">
          <span>Discount</span>
          <span class="totals-item-value">-<%= fmt(locals.discount) %></span>
        </div>
        <% } %>
        <div class="totals-item">
          <span>Tax</span>
          <span class="totals-item-value"><%= fmt(locals.taxes) %></span>
        </div>
      </div>
      <div class="totals-grand-row">
        <span class="totals-grand-label">Total Due</span>
        <span class="totals-grand-value"><%= fmt(locals.total) %></span>
      </div>
    </div>
  </div>

  <!-- SIGNATURE -->
  <% if (locals.show_signature && locals.signature) { %>
  <div class="signature-section">
    <div class="sig-label">Authorized Signature</div>
    <img class="sig-img" src="<%= locals.signature %>" alt="Signature" />
    <div class="sig-line"><%= locals.company_name || '' %></div>
  </div>
  <% } %>

  <!-- TERMS -->
  <% if (locals.terms) { %>
  <div class="terms-section">
    <div class="terms-label">Terms &amp; Conditions</div>
    <div class="terms-text"><%= locals.terms %></div>
  </div>
  <% } %>

  <!-- FOOTER BANNER -->
  <div class="footer-banner">
    <div class="footer-thanks">Thank you for your business.</div>
    <div class="footer-contact">
      <% if (locals.company_email) { %><div><%= locals.company_email %></div><% } %>
      <% if (locals.company_phone) { %><div><%= locals.company_phone %></div><% } %>
      <% if (locals.company_website) { %><div><%= locals.company_website %></div><% } %>
    </div>
  </div>

</div>
</body>
</html>
