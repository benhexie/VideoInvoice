<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Invoice — <%= locals.project_name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:ital,wght@0,100;0,300;0,400;0,600;0,700;1,300;1,400&display=swap" rel="stylesheet" />
  <style>
    <%- `
    :root {
      --accent: ${locals.theme_color || '#B8860B'};
      --accent-light: ${locals.theme_color_light || '#fdf8ec'};
    }
    ` %>

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    @page { size: A4; margin: 0; }

    body {
      font-family: 'Josefin Sans', 'Helvetica Neue', sans-serif;
      background: #f0ede8;
      color: #1a1a1a;
      font-size: 13px;
      line-height: 1.6;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    @media print {
      body { background: #fff; }
      * { animation: none !important; transition: none !important; }
      .page { box-shadow: none; margin: 0; }
    }

    .page {
      background: #ffffff;
      max-width: 800px;
      margin: 32px auto;
      overflow: hidden;
      box-shadow: 0 4px 40px rgba(0,0,0,0.12);
    }

    /* ── HEADER ─────────────────────────────────────────── */
    .header {
      padding: 52px 56px 40px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      position: relative;
      overflow: hidden;
    }

    .header-left {
      position: relative;
      z-index: 1;
    }

    .company-logo {
      max-height: 44px;
      width: auto;
      object-fit: contain;
      display: block;
      margin-bottom: 16px;
    }

    .company-name {
      font-size: 22px;
      font-weight: 600;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: #111111;
      line-height: 1;
      margin-bottom: 10px;
    }

    .company-meta {
      font-size: 10.5px;
      font-weight: 300;
      letter-spacing: 0.5px;
      color: #999999;
      line-height: 1.85;
    }

    /* Ghost "INVOICE" display text */
    .header-right {
      position: relative;
      z-index: 1;
      text-align: right;
      line-height: 1;
    }

    .invoice-ghost {
      font-size: 96px;
      font-weight: 100;
      letter-spacing: 6px;
      color: #f0f0f0;
      line-height: 1;
      user-select: none;
      text-transform: uppercase;
    }

    /* ── ACCENT BAND ────────────────────────────────────── */
    .accent-band {
      height: 6px;
      background: var(--accent);
    }

    /* ── META STRIP ─────────────────────────────────────── */
    .meta-strip {
      padding: 22px 56px;
      display: flex;
      gap: 0;
      align-items: center;
      border-bottom: 1px solid #e8e4de;
      background: #fdfcfb;
    }

    .meta-item {
      flex: 1;
      padding: 0 24px;
    }

    .meta-item:first-child { padding-left: 0; }
    .meta-item:last-child  { padding-right: 0; }

    .meta-item + .meta-item {
      border-left: 1px solid #e8e4de;
    }

    .meta-item-label {
      font-size: 8.5px;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 3px;
    }

    .meta-item-value {
      font-size: 12.5px;
      font-weight: 400;
      letter-spacing: 0.3px;
      color: #333333;
    }

    /* ── BILLING ────────────────────────────────────────── */
    .billing-section {
      padding: 32px 56px 24px;
      border-bottom: 1px solid #e8e4de;
    }

    .billing-label {
      font-size: 8.5px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 12px;
    }

    .client-name {
      font-size: 22px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #111111;
      margin-bottom: 6px;
    }

    .client-detail {
      font-size: 12px;
      color: #888888;
      font-weight: 300;
      line-height: 1.75;
      white-space: pre-line;
    }

    .client-email {
      font-size: 12px;
      color: #888888;
      font-weight: 300;
      margin-top: 3px;
    }

    /* ── TABLE ──────────────────────────────────────────── */
    .table-wrapper { padding: 28px 56px 0; }

    table { width: 100%; border-collapse: collapse; }

    thead th {
      font-size: 8.5px;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--accent);
      padding: 0 12px 12px 0;
      text-align: left;
      border-bottom: 2px solid var(--accent);
    }

    thead th:last-child { text-align: right; padding-right: 0; }
    thead th.num        { text-align: right; }

    tbody td {
      padding: 13px 12px 13px 0;
      font-size: 12.5px;
      color: #444444;
      font-weight: 300;
      letter-spacing: 0.2px;
      border-bottom: 1px solid #f0ede8;
      vertical-align: top;
    }

    tbody td:last-child { text-align: right; padding-right: 0; font-weight: 400; }
    tbody td.num        { text-align: right; }

    tbody tr:nth-child(even) { background: #fdfcfb; }
    tbody tr:last-child td { border-bottom: none; }

    /* ── TOTALS ─────────────────────────────────────────── */
    .totals-outer {
      display: flex;
      justify-content: flex-end;
      padding: 28px 56px 36px;
    }

    .totals-block { width: 320px; }

    .totals-line {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 6px 0;
      border-bottom: 1px solid #f0ede8;
    }

    .totals-line:last-of-type { border-bottom: none; }

    .totals-line-label {
      font-size: 11px;
      font-weight: 300;
      letter-spacing: 0.5px;
      color: #aaaaaa;
    }

    .totals-line-value {
      font-size: 12.5px;
      color: #555555;
      font-weight: 400;
    }

    .totals-line.discount .totals-line-value { color: #16a34a; }

    .totals-grand {
      border-top: 2px solid var(--accent);
      margin-top: 12px;
      padding-top: 16px;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }

    .totals-grand-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: #aaaaaa;
    }

    .totals-grand-value {
      font-size: 34px;
      font-weight: 600;
      letter-spacing: 1px;
      color: var(--accent);
      line-height: 1;
    }

    /* ── SIGNATURE ──────────────────────────────────────── */
    .signature-section {
      margin: 0 56px;
      padding: 22px 0;
      border-top: 1px solid #e8e4de;
    }

    .sig-label { font-size: 8.5px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: #cccccc; margin-bottom: 10px; }
    .sig-img   { max-height: 48px; max-width: 160px; object-fit: contain; display: block; }
    .sig-line  { border-top: 1px solid #d8d4ce; margin-top: 8px; padding-top: 5px; font-size: 10px; color: #bbbbbb; letter-spacing: 2px; text-transform: uppercase; }

    /* ── TERMS ──────────────────────────────────────────── */
    .terms-section {
      margin: 0 56px;
      padding: 18px 0;
      border-top: 1px solid #e8e4de;
    }

    .terms-label { font-size: 8.5px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase; color: var(--accent); margin-bottom: 8px; }
    .terms-text  { font-size: 11.5px; color: #aaaaaa; font-weight: 300; line-height: 1.85; white-space: pre-line; letter-spacing: 0.2px; }

    /* ── FOOTER ─────────────────────────────────────────── */
    .footer-rule {
      height: 1px;
      background: #e8e4de;
      margin: 0 56px;
    }

    .footer {
      padding: 22px 56px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer-thanks {
      font-size: 13px;
      font-weight: 300;
      font-style: italic;
      letter-spacing: 0.5px;
      color: #cccccc;
    }

    .footer-contact {
      font-size: 10px;
      color: #cccccc;
      font-weight: 300;
      text-align: right;
      line-height: 1.8;
      letter-spacing: 0.3px;
    }
  </style>
</head>
<body>
<%
const fmt = (n) => {
  const sym = locals.currency || '$';
  return sym + Number(n || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
};
const companyInitial = (locals.company_name || 'C').charAt(0).toUpperCase();
%>
<div class="page">

  <!-- HEADER -->
  <div class="header">
    <div class="header-left">
      <% if (locals.logo_url) { %>
        <img class="company-logo" src="<%= locals.logo_url %>" alt="Logo" />
      <% } %>
      <div class="company-name"><%= locals.company_name || '' %></div>
      <div class="company-meta">
        <% if (locals.company_address) { %><div><%= locals.company_address %></div><% } %>
        <% if (locals.company_phone)   { %><div><%= locals.company_phone %></div><% } %>
        <% if (locals.company_email)   { %><div><%= locals.company_email %></div><% } %>
        <% if (locals.company_website) { %><div><%= locals.company_website %></div><% } %>
      </div>
    </div>
    <div class="header-right">
      <div class="invoice-ghost">Invoice</div>
    </div>
  </div>

  <!-- ACCENT BAND -->
  <div class="accent-band"></div>

  <!-- META STRIP -->
  <div class="meta-strip">
    <div class="meta-item">
      <div class="meta-item-label">Date Issued</div>
      <div class="meta-item-value"><%= locals.date || new Date().toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></div>
    </div>
    <div class="meta-item">
      <div class="meta-item-label">Project</div>
      <div class="meta-item-value"><%= locals.project_name || '' %></div>
    </div>
    <div class="meta-item">
      <div class="meta-item-label">Status</div>
      <div class="meta-item-value">Due on Receipt</div>
    </div>
  </div>

  <!-- BILLING -->
  <div class="billing-section">
    <div class="billing-label">Prepared For</div>
    <div class="client-name"><%= locals.client_name || '' %></div>
    <div class="client-detail"><%= locals.client_address || '' %></div>
    <% if (locals.client_email) { %><div class="client-email"><%= locals.client_email %></div><% } %>
  </div>

  <!-- LINE ITEMS -->
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th style="width:50%">Description</th>
          <th class="num">Qty</th>
          <th class="num">Unit Price</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        <% (locals.line_items || []).forEach(function(item) { %>
        <tr>
          <td><%= item.description %></td>
          <td class="num"><%= Number(item.quantity || 0).toLocaleString('en-US', {maximumFractionDigits:2}) %></td>
          <td class="num"><%= fmt(item.unit_price) %></td>
          <td><%= fmt(item.total || (item.quantity * item.unit_price)) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- TOTALS -->
  <div class="totals-outer">
    <div class="totals-block">
      <div class="totals-line">
        <span class="totals-line-label">Subtotal</span>
        <span class="totals-line-value"><%= fmt(locals.subtotal) %></span>
      </div>
      <% if (locals.discount && Number(locals.discount) > 0) { %>
      <div class="totals-line discount">
        <span class="totals-line-label">Discount</span>
        <span class="totals-line-value">-<%= fmt(locals.discount) %></span>
      </div>
      <% } %>
      <div class="totals-line">
        <span class="totals-line-label">Tax</span>
        <span class="totals-line-value"><%= fmt(locals.taxes) %></span>
      </div>
      <div class="totals-grand">
        <span class="totals-grand-label">Total Due</span>
        <span class="totals-grand-value"><%= fmt(locals.total) %></span>
      </div>
    </div>
  </div>

  <!-- SIGNATURE -->
  <% if (locals.show_signature && locals.signature) { %>
  <div class="signature-section">
    <div class="sig-label">Authorized Signature</div>
    <img class="sig-img" src="<%= locals.signature %>" alt="Signature" />
    <div class="sig-line">Authorized · <%= locals.company_name || '' %></div>
  </div>
  <% } %>

  <!-- TERMS -->
  <% if (locals.terms) { %>
  <div class="terms-section">
    <div class="terms-label">Terms &amp; Conditions</div>
    <div class="terms-text"><%= locals.terms %></div>
  </div>
  <% } %>

  <!-- FOOTER -->
  <div class="footer-rule"></div>
  <div class="footer">
    <div class="footer-thanks">Thank you for your continued trust.</div>
    <div class="footer-contact">
      <% if (locals.company_email) { %><div><%= locals.company_email %></div><% } %>
      <% if (locals.company_phone) { %><div><%= locals.company_phone %></div><% } %>
      <% if (locals.company_website) { %><div><%= locals.company_website %></div><% } %>
    </div>
  </div>

</div>
</body>
</html>
