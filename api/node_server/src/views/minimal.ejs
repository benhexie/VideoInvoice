<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Invoice — <%= locals.project_name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    <%- `
    :root {
      --accent: ${locals.theme_color || '#111111'};
      --accent-light: ${locals.theme_color_light || '#f5f5f5'};
    }
    ` %>

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    @page { size: A4; margin: 0; }

    body {
      font-family: 'DM Sans', -apple-system, sans-serif;
      background: #fafafa;
      color: #111111;
      font-size: 13.5px;
      line-height: 1.55;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    @media print {
      body { background: #fff; }
      * { animation: none !important; transition: none !important; }
      .page { box-shadow: none; margin: 0; }
    }

    .mono { font-family: 'DM Mono', monospace; }

    .page {
      background: #ffffff;
      max-width: 800px;
      margin: 32px auto;
      padding: 0;
      box-shadow: 0 1px 12px rgba(0,0,0,0.07);
    }

    /* ── TOP ACCENT RULE ────────────────────────────────── */
    .accent-rule { height: 2px; background: var(--accent); }

    /* ── HEADER ─────────────────────────────────────────── */
    .header {
      padding: 40px 52px 28px;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }

    .company-section {}

    .company-name {
      font-size: 17px;
      font-weight: 700;
      color: #111;
      letter-spacing: -0.2px;
    }

    .company-meta {
      font-size: 12px;
      color: #999;
      margin-top: 4px;
      line-height: 1.65;
      font-weight: 300;
    }

    .company-logo {
      max-height: 36px;
      width: auto;
      object-fit: contain;
      filter: grayscale(100%);
      margin-bottom: 8px;
      display: block;
    }

    .invoice-section { text-align: right; }

    .invoice-title {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #999;
    }

    .invoice-date {
      font-size: 13px;
      font-weight: 400;
      color: #333;
      margin-top: 4px;
    }

    /* ── DIVIDER ────────────────────────────────────────── */
    .divider { border: none; border-top: 1px solid #e5e5e5; margin: 0 52px; }

    /* ── BILL TO / PROJECT ──────────────────────────────── */
    .meta-row {
      padding: 28px 52px;
      display: flex;
      gap: 60px;
    }

    .meta-col-label {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #bbb;
      margin-bottom: 6px;
    }

    .meta-col-name {
      font-size: 14px;
      font-weight: 600;
      color: #111;
      margin-bottom: 2px;
    }

    .meta-col-detail {
      font-size: 12px;
      color: #777;
      line-height: 1.6;
      font-weight: 300;
      white-space: pre-line;
    }

    /* ── TABLE ──────────────────────────────────────────── */
    .table-wrapper { padding: 0 52px; }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead th {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #999;
      padding: 10px 12px 10px 0;
      text-align: left;
      border-bottom: 2px solid #111;
    }

    thead th:last-child { text-align: right; padding-right: 0; }
    thead th.num        { text-align: right; }

    tbody td {
      padding: 11px 12px 11px 0;
      font-size: 13px;
      color: #333;
      border-bottom: 1px solid #ebebeb;
      vertical-align: top;
    }

    tbody td:last-child {
      text-align: right;
      padding-right: 0;
      font-family: 'DM Mono', monospace;
      font-weight: 500;
    }

    tbody td.num {
      text-align: right;
      font-family: 'DM Mono', monospace;
    }

    tbody tr:last-child td { border-bottom: none; }

    /* ── TOTALS ─────────────────────────────────────────── */
    .totals-outer {
      padding: 28px 52px 36px;
      display: flex;
      justify-content: flex-end;
    }

    .totals-block { width: 260px; }

    .totals-line {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 6px 0;
    }

    .totals-line-label {
      font-size: 12px;
      color: #888;
      font-weight: 400;
    }

    .totals-line-value {
      font-family: 'DM Mono', monospace;
      font-size: 13px;
      color: #333;
      font-weight: 400;
    }

    .totals-line.discount .totals-line-value { color: #16a34a; }

    .totals-grand {
      border-top: 2px solid #111;
      margin-top: 6px;
      padding-top: 10px;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }

    .totals-grand-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--accent);
    }

    .totals-grand-value {
      font-family: 'DM Mono', monospace;
      font-size: 20px;
      font-weight: 500;
      color: #111;
    }

    /* ── SIGNATURE ──────────────────────────────────────── */
    .signature-section {
      padding: 0 52px 28px;
    }

    .sig-rule { border-top: 1px solid #ccc; width: 200px; margin-bottom: 8px; }
    .sig-img  { max-height: 52px; max-width: 180px; object-fit: contain; display: block; margin-bottom: 6px; }
    .sig-name { font-size: 11px; color: #aaa; letter-spacing: 1px; text-transform: uppercase; }

    /* ── TERMS ──────────────────────────────────────────── */
    .terms-section {
      margin: 0 52px 32px;
      padding: 16px 0;
      border-top: 1px solid #ebebeb;
    }

    .terms-label { font-size: 10px; font-weight: 500; letter-spacing: 2px; text-transform: uppercase; color: #bbb; margin-bottom: 8px; }
    .terms-text  { font-size: 12px; color: #888; line-height: 1.75; white-space: pre-line; font-weight: 300; }

    /* ── FOOTER ─────────────────────────────────────────── */
    .footer {
      border-top: 1px solid #ebebeb;
      padding: 16px 52px;
      text-align: center;
      font-size: 11px;
      color: #ccc;
      font-weight: 300;
      letter-spacing: 0.5px;
    }

    .footer span + span::before { content: ' · '; }
  </style>
</head>
<body>
<%
const fmt = (n) => {
  const sym = locals.currency || '$';
  return sym + Number(n || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
};
%>
<div class="page">

  <!-- TOP ACCENT RULE -->
  <div class="accent-rule"></div>

  <!-- HEADER -->
  <div class="header">
    <div class="company-section">
      <% if (locals.logo_url) { %><img class="company-logo" src="<%= locals.logo_url %>" alt="Logo" /><% } %>
      <div class="company-name"><%= locals.company_name || '' %></div>
      <div class="company-meta">
        <%= locals.company_address || '' %><br>
        <% if (locals.company_phone) { %><%= locals.company_phone %><% } %>
        <% if (locals.company_phone && locals.company_email) { %> &nbsp;·&nbsp; <% } %>
        <% if (locals.company_email) { %><%= locals.company_email %><% } %>
        <% if ((locals.company_phone || locals.company_email) && locals.company_website) { %> &nbsp;·&nbsp; <% } %><% if (locals.company_website) { %><%= locals.company_website %><% } %>
      </div>
    </div>
    <div class="invoice-section">
      <div class="invoice-title">Invoice</div>
      <div class="invoice-date mono"><%= locals.date || new Date().toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></div>
    </div>
  </div>

  <hr class="divider" />

  <!-- BILL TO / PROJECT -->
  <div class="meta-row">
    <div>
      <div class="meta-col-label">Billed To</div>
      <div class="meta-col-name"><%= locals.client_name || '' %></div>
      <div class="meta-col-detail"><%= locals.client_address || '' %></div>
      <% if (locals.client_email) { %><div class="meta-col-detail"><%= locals.client_email %></div><% } %>
    </div>
    <div>
      <div class="meta-col-label">Project</div>
      <div class="meta-col-name"><%= locals.project_name || '' %></div>
    </div>
  </div>

  <hr class="divider" />

  <!-- LINE ITEMS -->
  <div class="table-wrapper" style="margin-top: 24px;">
    <table>
      <thead>
        <tr>
          <th style="width:50%">Description</th>
          <th class="num">Qty</th>
          <th class="num">Unit Price</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        <% (locals.line_items || []).forEach(function(item) { %>
        <tr>
          <td><%= item.description %></td>
          <td class="num"><%= Number(item.quantity || 0).toLocaleString('en-US', {maximumFractionDigits:2}) %></td>
          <td class="num"><%= fmt(item.unit_price) %></td>
          <td><%= fmt(item.total || (item.quantity * item.unit_price)) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- TOTALS -->
  <div class="totals-outer">
    <div class="totals-block">
      <div class="totals-line">
        <span class="totals-line-label">Subtotal</span>
        <span class="totals-line-value"><%= fmt(locals.subtotal) %></span>
      </div>
      <% if (locals.discount && Number(locals.discount) > 0) { %>
      <div class="totals-line discount">
        <span class="totals-line-label">Discount</span>
        <span class="totals-line-value">-<%= fmt(locals.discount) %></span>
      </div>
      <% } %>
      <div class="totals-line">
        <span class="totals-line-label">Tax</span>
        <span class="totals-line-value"><%= fmt(locals.taxes) %></span>
      </div>
      <div class="totals-grand">
        <span class="totals-grand-label">Total Due</span>
        <span class="totals-grand-value"><%= fmt(locals.total) %></span>
      </div>
    </div>
  </div>

  <!-- SIGNATURE -->
  <% if (locals.show_signature && locals.signature) { %>
  <div class="signature-section">
    <img class="sig-img" src="<%= locals.signature %>" alt="Signature" />
    <div class="sig-rule"></div>
    <div class="sig-name">Authorized Signature</div>
  </div>
  <% } %>

  <!-- TERMS -->
  <% if (locals.terms) { %>
  <div class="terms-section">
    <div class="terms-label">Terms &amp; Conditions</div>
    <div class="terms-text"><%= locals.terms %></div>
  </div>
  <% } %>

  <!-- FOOTER -->
  <div class="footer">
    <% if (locals.company_name) { %><span><%= locals.company_name %></span><% } %>
    <% if (locals.company_email) { %><span><%= locals.company_email %></span><% } %>
    <% if (locals.company_phone) { %><span><%= locals.company_phone %></span><% } %>
    <% if (locals.company_website) { %><span><%= locals.company_website %></span><% } %>
  </div>

</div>
</body>
</html>
