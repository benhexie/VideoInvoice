# ============================================================
# SnapQuote — Railway Environment Variables Reference
# ============================================================
# This file is NOT read by Railway. Copy each section's values
# into the corresponding service in the Railway dashboard.
# Never commit a real .env file — secrets go in Railway only.
# ============================================================


# ------------------------------------------------------------
# SERVICE: node_server  (root dir: api/node_server)
# ------------------------------------------------------------

PORT=8080

# Internal Railway URL to rust_engine — use Railway's private network:
# Format: http://<service-name>.railway.internal:<port>/path
RUST_AI_URL=http://rust-engine.railway.internal:3000/api/ai
PDF_ENGINE_URL=http://pdf-engine.railway.internal:5000

# Firebase Admin SDK (same values as rust_engine below)
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_CLIENT_EMAIL=your_client_email_here
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"


# ------------------------------------------------------------
# SERVICE: rust_engine  (root dir: api/rust_engine)
# ------------------------------------------------------------

PORT=3000

GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_CLIENT_EMAIL=your_client_email_here
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"


# ------------------------------------------------------------
# SERVICE: pdf_engine  (root dir: api/pdf_engine)
# ------------------------------------------------------------

PORT=5000
# pdf_engine has no secrets — no additional variables required.
